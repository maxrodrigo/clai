# VHS tape for setup clai demos
# Install: brew install charmbracelet/tap/vhs
# Source from demo tapes

Set Shell "bash"
Set Width 1200
Set Height 600
Set LineHeight 1.1
Set Theme "Catppuccin Mocha"
Set Padding 25
Set TypingSpeed 70ms
Set BorderRadius 15
Set Margin 40
# Set MarginFill "#f6ebd5"
Set MarginFill "#00add8"

Hide
Type "cd assets"
Enter
Sleep 500ms
Ctrl+L
Show

Sleep 1s
