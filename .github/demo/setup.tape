# VHS tape for setup clai demos
# Install: brew install charmbracelet/tap/vhs
# Source from demo tapes

Set Shell "bash"
Set Width 1200
Set Height 600

Set FontSize 18
Set Padding 24
Set TypingSpeed 70ms
Set BorderRadius 12
Set WindowBar Colorful
Set WindowBarSize 40

Set Margin 40
Set MarginFill "#0d1117"

Hide
Type "cd assets"
Enter
Sleep 500ms
Ctrl+L
Show

Sleep 1s
